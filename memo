        async function enemyTurn() {
            if (!isInBattle || !battleState.enemy || !currentBattleMonster) return;
            battleState.playerTurn = false;
            const motion = startBattleMotion(currentBattleMonster.group, slimeGroup);
            const enemy = battleState.enemy;
            const pStats = getPlayerBattleStats();
            const base = enemy.atk - pStats.def * 0.35;
            const enemyDmg = Math.max(1, Math.floor((base + Math.random() * 4) * battleState.guardRate));
            battleState.guardRate = 1.0;
            await sleep(motion.hitMs);
            playerState.hp -= enemyDmg;
            if (playerState.hp <= 0) {
                playerState.hp = Math.floor(getPlayerBattleStats().maxHp * 0.6);
                await sleep(Math.max(0, motion.totalMs - motion.hitMs + 120));
                endBattle(false, `${enemy.name}の こうげき！ ${enemyDmg} ダメージ\nぜんめつを まぬがれた...`, { keepEnemy: true });
                return;
            }
            updateBattleUI(`${enemy.name}の こうげき！ ${enemyDmg} ダメージ`);
            await sleep(Math.max(0, motion.totalMs - motion.hitMs + 150));
            battleState.playerTurn = true;
            battleState.busy = false;
            setBattleButtonsEnabled(true);
            updateBattleUI(`${enemy.name}の こうげき！ ${enemyDmg} ダメージ\nどうする？`);
        }

        function updateInventoryUI() {
            const list = document.getElementById('item-list');
            list.innerHTML = inventory.length ? inventory.join("<br>") : "なし";
            updatePlayerWindow();
        }

        async function fetchWeather(lat, lon) {
            try {
                const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
                const data = await res.json();
                const temp = Math.round(data.current_weather.temperature);
                const code = data.current_weather.weathercode;

                let statusText = "晴れ";
                if (code <= 3) {
                    currentWeather = "clear";
                    statusText = "晴れ";
                } else if (code === 45 || code === 48) {
                    currentWeather = "fog";
                    statusText = "霧";
                } else if ([51, 53, 55, 56, 57, 61, 63, 65, 66, 67, 80, 81, 82].includes(code)) {
                    currentWeather = "rain";
                    statusText = "雨";
                } else if ([71, 73, 75, 77, 85, 86].includes(code)) {
                    currentWeather = "snow";
                    statusText = "雪";
                } else {
                    currentWeather = "cloudy";
                    statusText = "曇り";
                }

                document.getElementById('weather-info').innerHTML = `${statusText}<br>${temp}°C`;
                applyTimeAndWeather();
            } catch (e) {
                console.error("fetchWeather Error:", e);
                document.getElementById('weather-info').textContent = "ERROR";
            }
        }

        function addLog(msg) {
            const el = document.getElementById('debug-log');
            if (el) el.textContent = "Log: " + msg;
            console.log("GameLog:", msg);
        }

        function isDefaultSendaiCoords(coords) {
            if (!coords) return false;
            return Math.abs(coords.lat - DEFAULT_FALLBACK.lat) < 0.0001 &&
                Math.abs(coords.lon - DEFAULT_FALLBACK.lon) < 0.0001;
        }

        function applyLocation(lat, lon, source) {
            baseCoords = { lat, lon };
            localStorage.setItem("dqw_last_gps_coords", JSON.stringify(baseCoords));
            addLog(`${source}: ${lat.toFixed(4)},${lon.toFixed(4)}`);
            fetchMapData(baseCoords.lat, baseCoords.lon);
            fetchWeather(baseCoords.lat, baseCoords.lon);
        }

        function gpsErrorMessage(err) {
            if (!err) return "不明なエラー";
            if (err.code === 1) return "位置情報が拒否されました。アドレスバー左の🔒から「位置情報」を許可してください。";
            if (err.code === 2) return "位置情報を取得できません。Windowsの「位置情報サービス」をオンにしてください。";
            if (err.code === 3) return "位置情報の取得がタイムアウトしました。もう一度お試しください。";
            return err.message || "位置情報エラー";
        }

        function startGpsWatch() {
            if (gpsWatchId !== null) return;
            gpsWatchId = navigator.geolocation.watchPosition(
                (p) => {
                    if (!gpsResolved) {
                        gpsResolved = true;
                        applyLocation(p.coords.latitude, p.coords.longitude, "GPS OK");
                    }
                },
                (err) => addLog("GPS Watch: " + gpsErrorMessage(err)),
                { enableHighAccuracy: true, maximumAge: 30000, timeout: 25000 }
            );
        }

        function requestGpsLocation() {
            if (!navigator.geolocation) {
                addLog("GPS Not Supported");
                useFallbackLocation("GPS非対応");
                return;
            }

            addLog(`Req GPS (${gpsRetryStage + 1}/3)...`);
            const stageOptions = [
                { enableHighAccuracy: false, timeout: 12000, maximumAge: 120000 },
                { enableHighAccuracy: true, timeout: 18000, maximumAge: 0 },
                { enableHighAccuracy: false, timeout: 25000, maximumAge: 600000 }
            ];
            const options = stageOptions[Math.min(gpsRetryStage, stageOptions.length - 1)];

            navigator.geolocation.getCurrentPosition(
                (p) => {
                    gpsResolved = true;
                    applyLocation(p.coords.latitude, p.coords.longitude, "GPS OK");
                    startGpsWatch();
                },
                (err) => {
                    addLog("GPS Fail: " + gpsErrorMessage(err));
                    if (gpsRetryStage < stageOptions.length - 1) {
                        gpsRetryStage += 1;
                        setTimeout(requestGpsLocation, 800);
                        return;
                    }
                    useFallbackLocation(gpsErrorMessage(err));
                },
                options
            );
        }

        function retryGps() {
            gpsRetryStage = 0;
            gpsResolved = false;
            if (gpsWatchId !== null) {
                navigator.geolocation.clearWatch(gpsWatchId);
                gpsWatchId = null;
            }
            addLog("Retry GPS...");
            showMessage("GPSを再取得しています...");
            requestGpsLocation();
        }

        function setManualPos() {
            const input = prompt("緯度,経度 を入力してください (例: 35.6812,139.7671)", `${baseCoords ? baseCoords.lat : DEFAULT_FALLBACK.lat},${baseCoords ? baseCoords.lon : DEFAULT_FALLBACK.lon}`);
            if (!input) return;
            const [lat, lon] = input.split(',').map(s => parseFloat(s.trim()));
            if (isNaN(lat) || isNaN(lon)) {
                alert("無効な入力です");
                return;
            }
            gpsResolved = true;
            applyLocation(lat, lon, "Manual Set");
        }

        function startTracking() {
            addLog("Req GPS...");
            requestGpsLocation();
        }

        function useFallbackLocation(reason) {
            let fallback = null;
            const saved = localStorage.getItem("dqw_last_gps_coords") || localStorage.getItem("dqw_last_coords");
            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    if (!isDefaultSendaiCoords(parsed)) fallback = parsed;
                } catch (e) { }
            }

            if (!fallback) {
                fallback = { ...DEFAULT_FALLBACK };
                addLog("Default: Sendai");
                showMessage(`${reason || "GPS未取得"}\n\n仙台駅付近で開始します。\n「GPS再取得」か「位置を手入力する」を使ってください。`);
            } else {
                addLog("Using Last GPS");
                showMessage(`${reason || "GPS未取得"}\n\n前回のGPS位置で開始します。`);
            }

            baseCoords = fallback;
            fetchMapData(baseCoords.lat, baseCoords.lon);
            fetchWeather(baseCoords.lat, baseCoords.lon);
        }

        function manualUpdate() {
            if (!baseCoords || isFetching) return;
            if (isInBattle || isMonsterNearbyForUpdate()) return;
            addLog("Manual Update...");
            const latScale = (2 * Math.PI * R) / 360, lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;
            fetchMapData(baseCoords.lat - (slimeGroup.position.z / latScale), baseCoords.lon + (slimeGroup.position.x / lonScale));
        }

        function isMonsterNearbyForUpdate() {
            for (const m of monsters) {
                if (!m.active) continue;
                if (slimeGroup.position.distanceTo(m.group.position) < 150) return true;
            }
            return false;
        }

        function createRipple(pos) {
            const geom = new THREE.RingGeometry(0.1, 0.2, 32);
            const mat = new THREE.MeshBasicMaterial({ color: 0x00ffff, transparent: true, opacity: 0.8, side: THREE.DoubleSide });
            const mesh = new THREE.Mesh(geom, mat);
            mesh.rotation.x = -Math.PI / 2;
            mesh.position.copy(pos);
            mesh.position.y = 0.2; // 少し浮かせ
            scene.add(mesh);
            ripples.push({ mesh, life: 1.0 });
        }

        function toggleBag() { const win = document.getElementById('inventory-window'); win.style.display = (win.style.display === 'block') ? 'none' : 'block'; }
        function showMessage(text) { const win = document.getElementById('message-window'); win.textContent = text; win.style.display = 'block'; setTimeout(() => win.style.display = 'none', 2500); }
        function updateRealTime() {
            const d = new Date();
            document.getElementById('clock-text').textContent = `${d.getHours().toString().padStart(2, '0')}:${d.getMinutes().toString().padStart(2, '0')}`;
            applyTimeAndWeather(); // 時間帯を再計算して色調整
            setTimeout(updateRealTime, 30000); // 30秒ごとに更新
        }
        function onWindowResize() { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); }

        function animate() {
            requestAnimationFrame(animate);
            const now = performance.now();
            updateDestinationDistanceTracker();
            updateBattleMotion(now);
            updateDefeatEffects(now);
            const dt = now - lastFrameAt;
            lastFrameAt = now;

            // 雨・雪パーティクルの更新
            updateWeatherParticles();
            // 雲オブジェクトの更新
            updateCloudObjects();

            // 建物と道路のフェードインアニメーション処理
            mapLayer.children.forEach(child => {
                if (child.userData && child.userData.animProgress !== undefined && child.userData.animProgress < 1) {
                    child.userData.animProgress += 0.03; // フェードイン速度
                    const t = child.userData.animProgress;
                    if (child.userData.type === "building") {
                        const targetScale = child.userData.targetScaleY;
                        child.scale.set(1, 1, 0.01 + (targetScale - 0.01) * t);
                        child.material.opacity = 0.88 * t;
                    }
                }
            });

            buildingOutlineLines.forEach(line => {
                if (line.userData && line.userData.id) {
                    const parent = mapLayer.children.find(c => c.userData.id === line.userData.id && c.userData.type === "building");
                    if (parent) {
                        line.material.opacity = parent.userData.animProgress;
                    }
                }
            });

            roadLayer.children.forEach(child => {
                if (child.userData && child.userData.animProgress !== undefined && child.userData.animProgress < 1) {
                    child.userData.animProgress += 0.03;
                    const t = child.userData.animProgress;
                    child.material.opacity = 0.85 * t;
                }
            });


            // Ripple processing
            for (let i = ripples.length - 1; i >= 0; i--) {
                const r = ripples[i];
                r.life -= 0.02;
                const s = 1 + (1 - r.life) * 15;
                r.mesh.scale.set(s, s, 1);
                r.mesh.material.opacity = r.life;
                if (r.life <= 0) {
                    scene.remove(r.mesh);
                    r.mesh.geometry.dispose();
                    r.mesh.material.dispose();
                    ripples.splice(i, 1);
                }
            }

            fpsAccum += dt;
            fpsFrames += 1;
            if (fpsAccum >= 600) {
                const fps = (fpsFrames * 1000) / fpsAccum;
                // 低FPS時は建物枠線を消して負荷を下げる
                const shouldShow = fps > 30;
                if (buildingOutlineVisible !== shouldShow) {
                    buildingOutlineVisible = shouldShow;
                }
                fpsAccum = 0;
                fpsFrames = 0;
            }
            // 低FPS時に加えて、プレイヤーから遠い建物枠線は隠して軽量化
            for (const line of buildingOutlineLines) {
                if (!buildingOutlineVisible) {
                    line.visible = false;
                    continue;
                }
                const center = line.userData.center || { x: 0, z: 0 };
                const dx = center.x - slimeGroup.position.x;
                const dz = center.z - slimeGroup.position.z;
                const distance = Math.sqrt(dx * dx + dz * dz);
                line.visible = distance <= BUILDING_OUTLINE_HIDE_DISTANCE;
            }
            if (!isInBattle && keyState['w']) {
                const dir = new THREE.Vector3(); camera.getWorldDirection(dir);
                dir.y = 0; dir.normalize();
                walkedDistance += 1.4;
                addQuestProgress("walk", 1.4);
                checkTutorialProgress();
                slimeGroup.position.addScaledVector(dir, 1.4);
                slimeGroup.quaternion.slerp(new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 0, 1), dir), 0.15);
                if (lastFetchedCoords) {
                    const latScale = (2 * Math.PI * R) / 360, lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;
                    const dx = ((baseCoords.lon + (slimeGroup.position.x / lonScale)) - lastFetchedCoords.lon) * lonScale;
                    const dz = ((baseCoords.lat - (slimeGroup.position.z / latScale)) - lastFetchedCoords.lat) * latScale;
                    if (Math.sqrt(dx * dx + dz * dz) > AUTO_UPDATE_THRESHOLD && !isMonsterNearbyForUpdate()) manualUpdate();
                }
            }
            handleInteraction();
            if (!isInBattle) checkStoryArrival();
            monsters.forEach(m => {
                if (!m.active) return;
                const now = Date.now();
                if (now > m.nextMoveTime) {
                    if (m.velocity.length() === 0) {
                        const a = Math.random() * Math.PI * 2;
                        m.velocity.set(Math.cos(a) * 0.2, 0, Math.sin(a) * 0.2);
                        m.nextMoveTime = now + 2000;
                    } else { m.velocity.set(0, 0, 0); m.nextMoveTime = now + 3000; }
                }
                m.group.position.add(m.velocity);
                m.mark.lookAt(camera.position);
            });
            if (isInBattle && battleState.center) {
                controls.target.lerp(battleState.center, 0.2);
                camera.lookAt(battleState.center.x, battleState.center.y + 4, battleState.center.z);
            } else {
                controls.target.lerp(slimeGroup.position, 0.1);
                controls.update();
            }
            renderer.render(scene, camera);
        }
        init();

        // =========================================================================
        // 【道路復活＆自動設置＆セーブ完全版】
        // =========================================================================

        window.DESTINATION_DISTANCE = 150;
        if (!window.activeDestinations) {
            window.activeDestinations = [];
        }

        let playerAtTestDestination = false;
        let currentStoryChapter = 0;

        /**
         * 修正版：マニュアルマップ更新（インクリメンタル読み込み対応）
         */
        async function manualUpdate() {
            if (isUpdatingMap || !baseCoords || !slimeGroup) return;
            isUpdatingMap = true;

            const btn = document.getElementById("debug-update-btn");
            if (btn) btn.textContent = "よみこみ中...";

            const R = 6378137;
            const latScale = (Math.PI * R) / 180;
            const lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;

            const currentLon = baseCoords.lon + (slimeGroup.position.x / lonScale);
            const currentLat = baseCoords.lat - (slimeGroup.position.z / latScale);

            await fetchMapData(currentLat, currentLon);

            if (window.activeDestinations.length === 0) {
                autoSpawnNextDestination();
            }

            isUpdatingMap = false;
            if (btn) btn.textContent = "マップ更新";
        }

        // --- ストーリーのセーブ＆ロード機能 ---
        function saveStoryProgress(chapterIndex) {
            localStorage.setItem("sanpo_rpg_story_chapter", chapterIndex);
            console.log(`[セーブ保存] ストーリーを第 ${chapterIndex} 章として保存。`);
        }

        function loadStoryProgress() {
            const savedChapter = localStorage.getItem("sanpo_rpg_story_chapter");
            if (savedChapter !== null) {
                currentStoryChapter = parseInt(savedChapter, 10);
                console.log(`[セーブ再開] 前回のクリア状態（第 ${currentStoryChapter} 章）から再開します。`);
                return currentStoryChapter;
            }
            currentStoryChapter = 0;
            return 0;
        }

        // --- 目的地の自動生成システム ---
        function autoSpawnNextDestination() {
            if (window.activeDestinations.length > 0) return;

            const currentChapter = loadStoryProgress();

            let destType = 'house';
            let destName = 'たびびとの宿';

            if (currentChapter === 1) {
                destType = 'cave';
                destName = '試練の洞窟';
            } else if (currentChapter >= 2) {
                destType = 'town';
                destName = '未知の街';
            }

            console.log(`[自動目的地設定] 物語の進行（第 ${currentChapter} 章）に合わせ、150m先に【${destName}】を配置します。`);
            spawnTargetDestination(destType, destName);
        }

        // --- 目的地生成・3D座標配置ロジック ---
        function spawnTargetDestination(type, name = "もくてきち") {
            if (typeof baseCoords === "undefined" || !baseCoords) {
                console.error("ベース座標が初期化されていないため設置を保留します。");
                return;
            }

            const angle = Math.random() * Math.PI * 2;
            const dx = Math.cos(angle) * window.DESTINATION_DISTANCE;
            const dz = Math.sin(angle) * window.DESTINATION_DISTANCE;

            const R = 6378137;
            const latScale = (Math.PI * R) / 180;
            const lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;

            const targetLon = baseCoords.lon + (dx / lonScale);
            const targetLat = baseCoords.lat - (dz / latScale);

            const destGroup = new THREE.Group();
            const material = new THREE.MeshStandardMaterial({ flatShading: true });

            if (type === 'house') {
                const bodyGeo = new THREE.BoxGeometry(4, 3, 4);
                material.color.setHex(0xddaa77);
                const body = new THREE.Mesh(bodyGeo, material.clone());
                body.position.y = 1.5;
                destGroup.add(body);

                const roofGeo = new THREE.ConeGeometry(3.5, 2.5, 4);
                material.color.setHex(0xcc4433);
                const roof = new THREE.Mesh(roofGeo, material.clone());
                roof.position.y = 4.25;
                roof.rotation.y = Math.PI / 4;
                destGroup.add(roof);
            } else if (type === 'town') {
                const buildingLayouts = [
                    { x: -2, z: -2, h: 4, w: 2, c: 0x5588aa },
                    { x: 2, z: -1, h: 6, w: 2.5, c: 0x6699bb }
                ];
                buildingLayouts.forEach(b => {
                    const bGeo = new THREE.BoxGeometry(b.w, b.h, b.w);
                    const bMat = material.clone();
                    bMat.color.setHex(b.c);
                    const mesh = new THREE.Mesh(bGeo, bMat);
                    mesh.position.set(b.x, b.h / 2, b.z);
                    destGroup.add(mesh);
                });
            } else if (type === 'cave') {
                const rockGeo = new THREE.DodecahedronGeometry(3, 0);
                material.color.setHex(0x666666);
                const mainRock = new THREE.Mesh(rockGeo, material.clone());
                mainRock.position.set(0, 1.5, 0);
                destGroup.add(mainRock);
            }

            if (typeof slimeGroup !== "undefined" && slimeGroup) {
                destGroup.position.set(slimeGroup.position.x + dx, 0, slimeGroup.position.z + dz);
            } else {
                destGroup.position.set(dx, 0, dz);
            }

            destGroup.userData = { name: name, type: type, lat: targetLat, lon: targetLon };

            if (typeof scene !== "undefined" && scene) {
                scene.add(destGroup);
                window.activeDestinations.push(destGroup);
            }

            if (typeof showMessage === "function") {
                showMessage(`${name} が 150m さきに 現れた！`);
            }
        }
        /**
 * プレイヤー追従・リアルタイム距離トラッカー（初期化エラー完全修正版）
 */
        function updateDestinationDistanceTracker() {
            if (!window.activeDestinations || window.activeDestinations.length === 0) {
                window.playerAtTestDestination = false;
                return;
            }
            if (typeof slimeGroup === "undefined" || !slimeGroup) return;

            const dest = window.activeDestinations[0];
            if (!dest) {
                window.playerAtTestDestination = false;
                return;
            }

            const dx = dest.position.x - slimeGroup.position.x;
            const dz = dest.position.z - slimeGroup.position.z;
            const currentDistance = Math.sqrt(dx * dx + dz * dz);

            // 15メートル以内に近づいた場合のみ反応
            if (currentDistance <= 15) {
                if (!window.playerAtTestDestination) {
                    window.playerAtTestDestination = true;

                    const destName = (dest.userData && dest.userData.name) ? dest.userData.name : "もくてきち";

                    if (typeof showMessage === "function") {
                        showMessage(`${destName} に ついた！\nこの状態で 画面を 【クリック（タップ）】 すると調査完了だ！`);
                    }
                }
            } else {
                window.playerAtTestDestination = false;
            }
        }

        /**
         * 画面クリック（タップ）時のイベントリスナー
         */
        window.addEventListener('click', () => {
            if (window.playerAtTestDestination && window.activeDestinations && window.activeDestinations.length > 0) {
                const dest = window.activeDestinations[0];
                if (dest && typeof scene !== "undefined" && scene) {

                    scene.remove(dest);
                    window.activeDestinations.shift();
                    window.playerAtTestDestination = false;

                    if (typeof currentStoryChapter !== "undefined") {
                        currentStoryChapter++;
                        if (typeof saveStoryProgress === "function") {
                            saveStoryProgress(currentStoryChapter);
                        }
                        console.log(`[Story Update] ストーリーが第 ${currentStoryChapter} 章に進行しました。`);
                    }

                    if (typeof showMessage === "function") {
                        showMessage("目的地を 調査した！\nストーリーが つぎへすすんだ！");
                    }

                    if (typeof autoSpawnNextDestination === "function") {
                        setTimeout(() => { autoSpawnNextDestination(); }, 3000);
                    }
                }
            }
        });



        // ページロード時に前回のクリアセーブデータを自動ロード
        document.addEventListener("DOMContentLoaded", () => {
            loadStoryProgress();
        });
        /**
         * 150m先（またはプレイヤーの目の前）に目的地オブジェクトを生成してシーンに追加する関数
         */
        function spawnTargetDestination(type = 'house', name = "もくてきち") {
            if (typeof scene === "undefined" || !scene) {
                console.error("sceneが定義されていません。");
                return;
            }
            if (typeof slimeGroup === "undefined" || !slimeGroup) {
                console.error("プレイヤー（slimeGroup）が見つかりません。");
                return;
            }

            // 150m先のオフセット位置を計算（ランダムな方向）
            const distance = 150;
            const angle = Math.random() * Math.PI * 2;
            const dx = Math.cos(angle) * distance;
            const dz = Math.sin(angle) * distance;

            // 目的地の3Dグループを作成
            const destGroup = new THREE.Group();
            const material = new THREE.MeshStandardMaterial({ color: 0xcc4433, flatShading: true });

            // 土台（家）のポリゴン
            const bodyGeo = new THREE.BoxGeometry(4, 3, 4);
            const body = new THREE.Mesh(bodyGeo, material);
            body.position.y = 1.5;
            destGroup.add(body);

            // 屋根のポリゴン
            const roofGeo = new THREE.ConeGeometry(3.5, 2.5, 4);
            const roof = new THREE.Mesh(roofGeo, new THREE.MeshStandardMaterial({ color: 0xddaa77, flatShading: true }));
            roof.position.y = 4.25;
            roof.rotation.y = Math.PI / 4;
            destGroup.add(roof);

            // プレイヤーの位置を基準にして座標を設定
            destGroup.position.set(slimeGroup.position.x + dx, 0, slimeGroup.position.z + dz);

            // データの保持
            destGroup.userData = { name: name, type: type };

            // シーンと管理配列（window.activeDestinations）に追加
            scene.add(destGroup);
            if (!window.activeDestinations) window.activeDestinations = [];
            window.activeDestinations.push(destGroup);

            console.log(`[目的地配置] ${name} を3D空間（X:${destGroup.position.x.toFixed(1)}, Z:${destGroup.position.z.toFixed(1)}）に配置しました。`);

            if (typeof showMessage === "function") {
                showMessage(`${name} が 150m さきに 現れた！`);
            }
        }

    </script>
    <script>
        window.playerAtTestDestination = false; 
