        function onPlayerItemAction(e) {
            const btn = e.target;
            if (!btn.classList.contains('item-act')) return;
            const idx = Number(btn.dataset.idx);
            const item = inventory[idx];
            if (!item) return;
            const def = ITEM_DEFS[item] || { type: "misc" };

            if (def.type === "heart") {
                if (def.cost > playerState.maxCost) {
                    showMessage(`コスト不足！(必要:${def.cost}/最大:${playerState.maxCost})`);
                    return;
                }
                if (playerState.equipment.heart) inventory.push(playerState.equipment.heart);
                playerState.equipment.heart = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "weapon") {
                if (playerState.equipment.weapon) inventory.push(playerState.equipment.weapon);
                playerState.equipment.weapon = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "shield") {
                if (playerState.equipment.shield) inventory.push(playerState.equipment.shield);
                playerState.equipment.shield = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "consumable") {
                const pStats = getPlayerBattleStats();
                if (def.heal) playerState.hp = Math.min(pStats.maxHp, playerState.hp + def.heal);
                if (def.mpHeal) playerState.mp = Math.min(pStats.maxMp, playerState.mp + def.mpHeal);
                inventory.splice(idx, 1);
                showMessage(`${item}を つかった`);
            }
            playerState.hp = Math.min(playerState.hp, getPlayerBattleStats().maxHp);
            playerState.mp = Math.min(playerState.mp, getPlayerBattleStats().maxMp);
            updateInventoryUI();
            updatePlayerWindow();
        }

        function setBattleButtonsEnabled(enabled) {
            ["battle-attack-btn", "battle-skill-btn", "battle-run-btn", "battle-guard-btn", "battle-item-btn"].forEach(id => {
                document.getElementById(id).disabled = !enabled;
            });
        }

        function enterBattleCamera(center) {
            battleState.cameraBackup = {
                position: camera.position.clone(),
                target: controls.target.clone(),
                enabled: controls.enabled
            };
            controls.enabled = false;
            battleState.center = center.clone();
            camera.position.set(center.x, center.y + 28, center.z + 40);
            camera.lookAt(center.x, center.y + 4, center.z);
        }

        function leaveBattleCamera() {
            if (!battleState.cameraBackup) return;
            camera.position.copy(battleState.cameraBackup.position);
            controls.target.copy(battleState.cameraBackup.target);
            controls.enabled = battleState.cameraBackup.enabled;
            battleState.cameraBackup = null;
        }

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function startBattleMotion(attackerGroup, targetGroup, variant = null) {
            const v = variant || [
                { dashMs: 260, holdMs: 100, backMs: 280, reach: 6.5 },
                { dashMs: 220, holdMs: 150, backMs: 300, reach: 5.8 },
                { dashMs: 300, holdMs: 80, backMs: 240, reach: 7.2 }
            ][Math.floor(Math.random() * 3)];
            const origin = attackerGroup.position.clone();
            const targetFlat = targetGroup.position.clone().sub(attackerGroup.position).setY(0);
            const distance = targetFlat.length();
            const travel = Math.max(3.8, Math.min(v.reach, distance - 2.4));
            const toward = targetFlat.normalize().multiplyScalar(travel);
            battleState.animation = {
                actor: attackerGroup,
                origin,
                dashPos: origin.clone().add(toward),
                phase: "dash",
                startedAt: performance.now(),
                dashMs: v.dashMs,
                holdMs: v.holdMs,
                backMs: v.backMs
            };
            return { hitMs: v.dashMs + Math.floor(v.holdMs * 0.6), totalMs: v.dashMs + v.holdMs + v.backMs };
        }

        function updateBattleMotion(now) {
            const anim = battleState.animation;
            if (!anim) return;
            if (anim.phase === "dash") {
                const t = Math.min(1, (now - anim.startedAt) / anim.dashMs);
                anim.actor.position.lerpVectors(anim.origin, anim.dashPos, t);
                if (t >= 1) {
                    anim.phase = "hold";
                    anim.startedAt = now;
                }
                return;
            }
            if (anim.phase === "hold") {
                const t = (now - anim.startedAt) / anim.holdMs;
                anim.actor.position.copy(anim.dashPos);
                if (t >= 1) {
                    anim.phase = "back";
                    anim.startedAt = now;
                }
                return;
            }
            const t = Math.min(1, (now - anim.startedAt) / anim.backMs);
            anim.actor.position.lerpVectors(anim.dashPos, anim.origin, t);
            if (t >= 1) battleState.animation = null;
        }

        function beginBattle(monster) {
            if (isInBattle || !monster.active) return;
            isInBattle = true;
            currentBattleMonster = monster;
            monster.active = false;
            monster.mark.visible = true;

            const center = slimeGroup.position.clone();
            const playerPos = center.clone().add(new THREE.Vector3(-11, 0, 8));
            const enemyPos = center.clone().add(new THREE.Vector3(11, 0, -8));
            slimeGroup.position.copy(playerPos);
            monster.group.position.copy(enemyPos);
            slimeGroup.lookAt(enemyPos);
            monster.group.lookAt(playerPos);
            enterBattleCamera(center);

            battleState.enemy = { ...monster.stats };
            battleState.playerTurn = true;
            battleState.busy = false;
            battleState.guardRate = 1.0;
            const job = JOB_DEFS[playerState.job] || JOB_DEFS["戦士"];
            document.getElementById('battle-skill-btn').textContent = job.skill || "スキル";
            if (battleState.enemy.isMega) {
                showMessage(`メガモンスター ${battleState.enemy.name}\nが あらわれた！！`);
            }
            updateBattleUI(`${battleState.enemy.name} が あらわれた！`);
            setBattleButtonsEnabled(true);
            document.getElementById('battle-status-window').style.display = 'block';
            document.getElementById('battle-command-window').style.display = 'block';
