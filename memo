        function updateBattleUI(logText) {
            updateStatusBar();
            const enemy = battleState.enemy || { name: "まもの", lv: 1, hp: 0, maxHp: 0 };
            const pStats = getPlayerBattleStats();
            document.getElementById('battle-player-hp').textContent = `ゆうしゃ Lv${playerState.lv} HP: ${Math.max(0, playerState.hp)}/${pStats.maxHp} MP:${playerState.mp}/${playerState.maxMp}`;
            document.getElementById('battle-enemy-hp').textContent = `${enemy.name} Lv${enemy.lv} HP: ${Math.max(0, enemy.hp)}/${enemy.maxHp}`;
            document.getElementById('battle-log').textContent = logText;
