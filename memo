        function grantExp(exp) {
            playerState.exp += exp;
            let lvupCount = 0;
            while (playerState.exp >= playerState.nextExp) {
                playerState.exp -= playerState.nextExp;
                playerState.lv += 1;
                playerState.nextExp = Math.floor(playerState.nextExp * 1.4);
                playerState.maxHp += LV_UP_TABLE.hp;
                playerState.maxMp += LV_UP_TABLE.mp;
                playerState.atk += LV_UP_TABLE.atk;
                playerState.def += LV_UP_TABLE.def;
                playerState.maxCost += LV_UP_TABLE.cost;
                playerState.hp = getPlayerBattleStats().maxHp;
                playerState.mp = getPlayerBattleStats().maxMp;
                lvupCount += 1;
            }
            return lvupCount;
        }

        function enemyDrop(enemy, preferHeart = false) {
            if (!enemy || !enemy.drops || enemy.drops.length === 0) return null;
            const rate = enemy.isMega ? 0.88 : 0.62;
            if (Math.random() > rate) return null;
            const hearts = enemy.drops.filter(d => ITEM_DEFS[d]?.type === "heart");
            if (preferHeart && hearts.length && Math.random() > 0.25) {
                return hearts[Math.floor(Math.random() * hearts.length)];
            }
            return enemy.drops[Math.floor(Math.random() * enemy.drops.length)];
        }

        function spawnPurpleMist(worldPos, scale = 1) {
            const group = new THREE.Group();
            group.position.copy(worldPos);
            const parts = [];
            for (let i = 0; i < 10; i++) {
                const s = new THREE.Mesh(
                    new THREE.SphereGeometry((1.2 + Math.random() * 1.8) * scale, 6, 6),
                    new THREE.MeshBasicMaterial({ color: 0x9933ff, transparent: true, opacity: 0.65 })
                );
                s.position.set((Math.random() - 0.5) * 5 * scale, 1 + Math.random() * 4 * scale, (Math.random() - 0.5) * 5 * scale);
                group.add(s);
                parts.push(s);
            }
            scene.add(group);
            defeatEffects.push({ group, parts, start: performance.now(), duration: 1600 });
            return group;
        }

        function updateDefeatEffects(now) {
            for (let i = defeatEffects.length - 1; i >= 0; i--) {
                const eff = defeatEffects[i];
                const t = (now - eff.start) / eff.duration;
                if (t >= 1) {
                    scene.remove(eff.group);
                    eff.parts.forEach(p => p.geometry?.dispose());
                    defeatEffects.splice(i, 1);
                    continue;
                }
                eff.parts.forEach(p => {
                    p.material.opacity = 0.7 * (1 - t);
                    p.scale.setScalar(1 + t * 1.8);
                    p.position.y += 0.04;
                });
            }
        }

        async function handleEnemyDefeated(damageLog) {
            const enemy = battleState.enemy;
            if (!enemy || !currentBattleMonster) return;
            battleState.busy = true;
            setBattleButtonsEnabled(false);
            document.getElementById('battle-command-window').style.display = 'none';
            updateBattleUI(`${damageLog}\n${enemy.name}を たおした！`);

            const mistPos = currentBattleMonster.group.position.clone();
            mistPos.y += enemy.isMega ? 6 : 3;
            spawnPurpleMist(mistPos, enemy.isMega ? 2.2 : 1.2);

            currentBattleMonster.group.children.forEach(c => {
                if (c.material) {
                    c.material.transparent = true;
                    c.material.opacity = 0.85;
                }
            });

            await sleep(500);
            const dropped = enemyDrop(enemy, true);
            if (dropped) {
                inventory.push(dropped);
                updateInventoryUI();
                const isHeart = ITEM_DEFS[dropped]?.type === "heart";
                showMessage(isHeart
                    ? `紫の靄の中から\n${dropped}が 落ちてきた！`
                    : `${dropped}を てにいれた！`);
                updateBattleUI(`${damageLog}\n${enemy.name}を たおした！\n${dropped}を おとした！`);
            }

            await sleep(1100);
            endBattle(true, `${damageLog}\n${enemy.name}を たおした！`, { skipDrop: true, dropped });
        }

        function endBattle(isWin, logText, options = {}) {
            updateBattleUI(logText);
            setTimeout(() => {
                if (isWin && battleState.enemy) {
                    const gained = battleState.enemy.exp;
                    const gainedGold = battleState.enemy.isMega ? (50 + battleState.enemy.lv * 12) : (8 + battleState.enemy.lv * 5);
                    const lvups = grantExp(gained);
                    const dropped = options.dropped ?? (options.skipDrop ? null : enemyDrop(battleState.enemy));
                    playerState.gold += gainedGold;
                    if (dropped && !options.skipDrop) inventory.push(dropped);
                    addQuestProgress("battle", 1);
                    storyState.battleWins += 1;
                    checkTutorialProgress();
                    updateInventoryUI();
                    const lvText = lvups > 0 ? `\nLvが ${lvups} あがった！` : "";
                    const dropText = dropped ? `\n${dropped} を てにいれた！` : "";
                    if (!options.dropped) {
                        showMessage(`${gained} EXP / ${gainedGold}G かくとく！${lvText}${dropText}`);
                    } else {
                        showMessage(`${gained} EXP / ${gainedGold}G かくとく！${lvText}`);
                    }
                }
                if (currentBattleMonster) {
                    if (options.keepEnemy) {
                        currentBattleMonster.active = true;
                        currentBattleMonster.mark.visible = false;
                    } else {
                        scene.remove(currentBattleMonster.group);
                    }
                    currentBattleMonster = null;
                }
                document.getElementById('battle-status-window').style.display = 'none';
                document.getElementById('battle-command-window').style.display = 'none';
                isInBattle = false;
                battleState.enemy = null;
                battleState.animation = null;
                battleState.busy = false;
                battleState.playerTurn = true;
                leaveBattleCamera();
                updatePlayerWindow();
            }, 600);
        }

        async function onBattleAttack() {
            if (!isInBattle || battleState.busy || !battleState.playerTurn) return;
            const enemy = battleState.enemy;
            if (!enemy) return;
            battleState.busy = true;
            setBattleButtonsEnabled(false);
            const motion = startBattleMotion(slimeGroup, currentBattleMonster.group);
            const pStats = getPlayerBattleStats();
            const base = pStats.atk - enemy.def * 0.45;
            const playerDmg = Math.max(2, Math.floor(base + Math.random() * 5));
            await sleep(motion.hitMs);
            enemy.hp -= playerDmg;
            if (enemy.hp <= 0) {
                updateBattleUI(`${enemy.name}に ${playerDmg} ダメージ！\n${enemy.name}を たおした！`);
                await sleep(Math.max(0, motion.totalMs - motion.hitMs + 120));
                await handleEnemyDefeated(`${enemy.name}に ${playerDmg} ダメージ！`);
                return;
            }
            updateBattleUI(`${enemy.name}に ${playerDmg} ダメージ！\n${enemy.name}の こうげき...`);
            await sleep(Math.max(0, motion.totalMs - motion.hitMs + 140));
            await enemyTurn();
        }

        async function onBattleSkill() {
            if (!isInBattle || battleState.busy || !battleState.playerTurn) return;
            const enemy = battleState.enemy;
            if (!enemy) return;

            const job = JOB_DEFS[playerState.job] || JOB_DEFS["戦士"];
            if (playerState.mp < job.mpCost) {
                updateBattleUI("MPが たりない！");
                return;
            }

            playerState.mp -= job.mpCost;
            battleState.busy = true;
            setBattleButtonsEnabled(false);
            const motion = startBattleMotion(slimeGroup, currentBattleMonster.group, { dashMs: 240, holdMs: 200, backMs: 300, reach: 7.8 });

            const pStats = getPlayerBattleStats();
            let logText = "";
            if (job.skill === "ホイミ") {
                const healAmount = job.heal || 25;
                playerState.hp = Math.min(pStats.maxHp, playerState.hp + healAmount);
                logText = `ホイミ！ HPが ${healAmount} かいふくした！\n${enemy.name}の こうげき...`;
                await sleep(motion.hitMs);
            } else {
                const dmg = Math.max(5, Math.floor((pStats.atk * (job.skillDmg || 1.3)) - enemy.def * 0.4 + Math.random() * 8));
                await sleep(motion.hitMs);
                enemy.hp -= dmg;
                if (enemy.hp <= 0) {
                    updateBattleUI(`${job.skill}！ ${dmg} ダメージ！\n${enemy.name}を たおした！`);
                    await sleep(Math.max(0, motion.totalMs - motion.hitMs + 140));
                    await handleEnemyDefeated(`${job.skill}！ ${dmg} ダメージ！`);
                    return;
                }
                logText = `${job.skill}！ ${dmg} ダメージ！\n${enemy.name}の こうげき...`;
            }

            updateBattleUI(logText);
            await sleep(Math.max(0, motion.totalMs - motion.hitMs + 150));
            await enemyTurn();
        }

        async function onBattleRun() {
            if (!isInBattle || battleState.busy || !battleState.playerTurn) return;
            battleState.busy = true;
            setBattleButtonsEnabled(false);
            if (Math.random() > 0.4) {
                endBattle(false, "うまく にげきれた！", { keepEnemy: true });
            } else {
                updateBattleUI("にげられない！");
                await sleep(260);
                await enemyTurn();
            }
        }

        async function onBattleGuard() {
            if (!isInBattle || battleState.busy || !battleState.playerTurn) return;
            battleState.busy = true;
            battleState.guardRate = 0.45;
            setBattleButtonsEnabled(false);
            updateBattleUI("みを まもっている...");
            await sleep(300);
            await enemyTurn();
