        async function onBattleItem() {
            if (!isInBattle || battleState.busy || !battleState.playerTurn) return;
            battleState.busy = true;
            setBattleButtonsEnabled(false);
            if (inventory.length === 0) {
                updateBattleUI("どうぐが ない！");
                battleState.busy = false;
                setBattleButtonsEnabled(true);
                return;
            }
            const itemIndex = inventory.findIndex(name => (ITEM_DEFS[name]?.type) === "consumable");
            if (itemIndex < 0) {
                updateBattleUI("せんとうで つかえるどうぐが ない！");
                battleState.busy = false;
                setBattleButtonsEnabled(true);
                return;
            }
            const itemName = inventory.splice(itemIndex, 1)[0];
            const heal = ITEM_DEFS[itemName]?.heal || 8;
            playerState.hp = Math.min(getPlayerBattleStats().maxHp, playerState.hp + heal);
            updateInventoryUI();
            updatePlayerWindow();
            updateBattleUI(`${itemName}を つかった！\nHPが かいふくした`);
            await sleep(420);
            await enemyTurn();
