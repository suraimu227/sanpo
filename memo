                animProgress: 0,
                targetScaleY: 1.0 + Math.random() * 2.0
            };
            buildingMesh.scale.set(1, 1, 0.01);
            mapLayer.add(buildingMesh);

            const outlinePts = [...pts2D, pts2D[0]];
            const lineGeom = new THREE.BufferGeometry().setFromPoints(
                outlinePts.map(p => new THREE.Vector3(p.x, 0.28, p.y))
            );
            const line = new THREE.Line(lineGeom, buildingLineMaterial.clone());
            const centerX = pts2D.reduce((sum, p) => sum + p.x, 0) / pts2D.length;
            const centerZ = pts2D.reduce((sum, p) => sum + p.y, 0) / pts2D.length;
            line.userData = { id: el.id, type: "building_line", center: { x: centerX, z: centerZ } };
            line.material.transparent = true;
            line.material.opacity = 0;
            mapLayer.add(line);
            buildingOutlineLines.push(line);
        }

        function createRoadMesh(el, pts2D, roadMaterial) {
            if (loadedMapElements.has(el.id)) return;
            loadedMapElements.add(el.id);

            const halfWidth = 4.8;
            const pts = pts2D;
            if (pts.length < 2) return;

            const segLeft = [];
            const segRight = [];
            for (let i = 0; i < pts.length; i++) {
                const prev = pts[Math.max(0, i - 1)];
                const next = pts[Math.min(pts.length - 1, i + 1)];
                const dir = new THREE.Vector2(next.x - prev.x, next.y - prev.y);
                if (dir.lengthSq() < 0.0001) continue;
                dir.normalize();
                const n = new THREE.Vector2(-dir.y, dir.x).multiplyScalar(halfWidth);
                segLeft.push(pts[i].x + n.x, 0.245, pts[i].y + n.y);
                segRight.push(pts[i].x - n.x, 0.245, pts[i].y - n.y);
            }

            const count = segLeft.length / 3;
            if (count < 2) return;

            const allPos = [];
            const allIdx = [];
            for (let i = 0; i < count - 1; i++) {
                const a = i * 2;
                allIdx.push(a, a + 1, a + 2, a + 1, a + 3, a + 2);
            }
            for (let i = 0; i < count; i++) {
                allPos.push(segLeft[i * 3], segLeft[i * 3 + 1], segLeft[i * 3 + 2]);
                allPos.push(segRight[i * 3], segRight[i * 3 + 1], segRight[i * 3 + 2]);
            }

            const geom = new THREE.BufferGeometry();
            geom.setAttribute("position", new THREE.Float32BufferAttribute(allPos, 3));
            geom.setIndex(allIdx);

            const mat = roadMaterial.clone();
            mat.transparent = true;
            mat.opacity = 0;

            const mesh = new THREE.Mesh(geom, mat);
            mesh.userData = { id: el.id, type: "road", animProgress: 0 };
            roadLayer.add(mesh);
        }

        function cleanupRemoteMapElements() {
            if (!slimeGroup) return;
            const cleanupDistance = 700;
            const playerPos = slimeGroup.position;

            for (let i = mapLayer.children.length - 1; i >= 0; i--) {
                const child = mapLayer.children[i];
                let dist = 9999;
                if (child.userData.type === "building") {
                    dist = child.position.distanceTo(playerPos);
                } else if (child.userData.type === "building_line" && child.userData.center) {
                    const cx = child.userData.center.x;
                    const cz = child.userData.center.z;
                    dist = Math.sqrt((cx - playerPos.x) ** 2 + (cz - playerPos.z) ** 2);
                }

                if (dist > cleanupDistance) {
                    mapLayer.remove(child);
                    if (child.geometry) child.geometry.dispose();
                    if (child.material) {
                        if (Array.isArray(child.material)) child.material.forEach(m => m.dispose());
                        else child.material.dispose();
                    }

                    if (child.userData && child.userData.id) {
                        loadedMapElements.delete(child.userData.id);
                    }
                }
            }

            for (let i = buildingOutlineLines.length - 1; i >= 0; i--) {
                const line = buildingOutlineLines[i];
                const cx = line.userData.center ? line.userData.center.x : 0;
                const cz = line.userData.center ? line.userData.center.z : 0;
                const dist = Math.sqrt((cx - playerPos.x) ** 2 + (cz - playerPos.z) ** 2);
                if (dist > cleanupDistance) {
                    buildingOutlineLines.splice(i, 1);
                }
            }

            for (let i = roadLayer.children.length - 1; i >= 0; i--) {
                const child = roadLayer.children[i];
                if (child.geometry) {
                    if (!child.geometry.boundingSphere) child.geometry.computeBoundingSphere();
                    const center = child.geometry.boundingSphere.center;
                    const dist = center.distanceTo(playerPos);
                    if (dist > cleanupDistance) {
                        roadLayer.remove(child);
                        child.geometry.dispose();
                        if (child.material) child.material.dispose();
                        if (child.userData && child.userData.id) {
                            loadedMapElements.delete(child.userData.id);
                        }
                    }
                }
            }
        }

