<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8">
    <title>DQW 3D - Solid Sync & Emotes</title>
    <link rel="icon" href="/static/favicon.ico" type="image/x-icon">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=Press+Start+2P&display=swap"
        rel="stylesheet">
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #050811;
            font-family: 'DotGothic16', 'Press Start 2P', cursive;
            touch-action: none;
        }

        /* Glassmorphism panel base */
        .glass-panel {
            background: rgba(10, 16, 28, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
            border-radius: 12px;
            color: #fff;
            padding: 12px;
            box-sizing: border-box;
        }

        #gui {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 1000;
            width: 140px;
            text-align: center;
        }

        #clock-text {
            font-size: 18px;
            font-weight: bold;
            letter-spacing: 2px;
            display: block;
            margin-bottom: 6px;
            color: #00ffff;
            text-shadow: 0 0 8px rgba(0, 255, 255, 0.5);
        }

        #weather-info {
            font-size: 12px;
            line-height: 1.4;
            margin-bottom: 10px;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            padding-top: 6px;
            color: #ddd;
        }

        #debug-update-btn {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 6px;
            padding: 5px;
            font-family: 'DotGothic16';
            font-size: 10px;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s;
        }

        #debug-update-btn:active {
            background: rgba(255, 255, 255, 0.25);
        }

        #bag-gui {
            position: absolute;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1100;
            display: flex;
            gap: 8px;
            width: 90%;
            max-width: 480px;
            justify-content: center;
        }

        .game-btn {
            background: linear-gradient(135deg, rgba(0, 180, 255, 0.25) 0%, rgba(0, 100, 255, 0.15) 100%);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            color: #fff;
            border: 1px solid rgba(0, 180, 255, 0.4);
            border-radius: 10px;
            padding: 12px 10px;
            font-family: 'DotGothic16';
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            flex: 1;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.35);
            transition: all 0.2s;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
        }

        .game-btn:active {
            transform: scale(0.95);
            background: linear-gradient(135deg, rgba(0, 180, 255, 0.4) 0%, rgba(0, 100, 255, 0.3) 100%);
            border-color: rgba(0, 220, 255, 0.6);
        }

        #inventory-window,
        #player-window,
        #quest-window {
            position: absolute;
            bottom: 75px;
            left: 5%;
            width: 90%;
            max-height: 55vh;
            overflow-y: auto;
            z-index: 1200;
            display: none;
            font-size: 12px;
            line-height: 1.6;
        }

        .item-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            margin-bottom: 6px;
            background: rgba(255, 255, 255, 0.05);
            padding: 6px 10px;
            border-radius: 6px;
        }

        .item-act {
            background: rgba(0, 200, 255, 0.2);
            color: #fff;
            border: 1px solid rgba(0, 200, 255, 0.4);
            border-radius: 4px;
            padding: 3px 8px;
            font-size: 11px;
            cursor: pointer;
            font-family: 'DotGothic16';
        }

        .item-act:active {
            background: rgba(0, 200, 255, 0.4);
        }

        .save-btn {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 6px;
            font-size: 11px;
            padding: 6px 12px;
            cursor: pointer;
            margin-top: 6px;
            font-family: 'DotGothic16';
        }

        .save-btn:active {
            background: rgba(255, 255, 255, 0.2);
        }

        #message-window {
            position: absolute;
            bottom: 140px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1500;
            background: rgba(10, 20, 40, 0.85);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(0, 180, 255, 0.5);
            border-radius: 12px;
            color: #fff;
            padding: 12px 20px;
            font-size: 12px;
            min-width: 250px;
            max-width: 85%;
            display: none;
            text-align: center;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
        }

        #map-loading {
            position: fixed;
            inset: 0;
            z-index: 2000;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(5, 8, 17, 0.8);
            backdrop-filter: blur(5px);
        }

        #map-loading.visible {
            display: flex;
        }

        .load-window {
            background: rgba(10, 16, 28, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 16px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        }

        .load-text {
            color: #fff;
            font-size: 12px;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .small-load-bar {
            width: 180px;
            height: 8px;
            border-radius: 4px;
            background: rgba(255, 255, 255, 0.1);
            position: relative;
            overflow: hidden;
        }

        .small-load-fill {
            height: 100%;
            width: 60px;
            background: #00b4ff;
            border-radius: 4px;
            position: absolute;
            animation: bar-move 1.2s linear infinite;
        }

        .battle-window {
            position: fixed;
            z-index: 2200;
            display: none;
        }

        #battle-status-window {
            left: 5%;
            top: 20px;
            width: 90%;
            max-width: 480px;
        }

        #battle-command-window {
            bottom: 20px;
            left: 5%;
            width: 90%;
            max-width: 480px;
        }

        #battle-title {
            font-size: 15px;
            margin-bottom: 6px;
            letter-spacing: 1px;
            color: #ff3b30;
            text-shadow: 0 0 6px rgba(255, 60, 50, 0.3);
            font-weight: bold;
        }

        .battle-hp {
            font-size: 12px;
            line-height: 1.6;
            margin-bottom: 8px;
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
            padding: 6px 0;
        }

        #battle-log {
            min-height: 38px;
            font-size: 12px;
            line-height: 1.5;
            color: #fff;
            white-space: pre-line;
        }

        .battle-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .battle-btn {
            background: linear-gradient(135deg, rgba(255, 59, 48, 0.2) 0%, rgba(255, 59, 48, 0.1) 100%);
            color: #fff;
            border: 1px solid rgba(255, 59, 48, 0.4);
            border-radius: 8px;
            padding: 10px 6px;
            font-family: 'DotGothic16';
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .battle-btn:active {
            background: rgba(255, 59, 48, 0.35);
        }

        .game-overlay {
            position: fixed;
            inset: 0;
            z-index: 3000;
            background: rgba(5, 8, 17, 0.85);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 12px;
            box-sizing: border-box;
        }

        .game-overlay.open {
            display: flex;
        }

        .overlay-panel {
            background: rgba(10, 16, 28, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 16px;
            color: #fff;
            width: min(480px, 94vw);
            max-height: 85vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);
        }

        .overlay-title {
            padding: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
            font-size: 16px;
            font-weight: bold;
            text-align: center;
        }

        .overlay-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            padding: 8px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.2);
        }

        .overlay-tab {
            flex: 1;
            min-width: 60px;
            background: rgba(255, 255, 255, 0.05);
            color: #ccc;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            padding: 8px 4px;
            font-family: 'DotGothic16';
            font-size: 11px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .overlay-tab.active {
            border-color: rgba(0, 180, 255, 0.5);
            background: rgba(0, 180, 255, 0.15);
            color: #fff;
        }

        .overlay-body {
            padding: 14px;
            overflow-y: auto;
            font-size: 12px;
            line-height: 1.6;
            flex: 1;
            touch-action: auto;
        }

        .overlay-close {
            margin: 10px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            font-family: 'DotGothic16';
            cursor: pointer;
            transition: all 0.2s;
        }

        .overlay-close:active {
            background: rgba(255, 255, 255, 0.15);
        }

        .prep-equip-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
            gap: 6px;
            background: rgba(255, 255, 255, 0.03);
            padding: 6px 10px;
            border-radius: 6px;
        }

        .story-goal-card {
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.02);
            border-radius: 8px;
            padding: 8px;
            margin-bottom: 8px;
        }

        .story-goal-card.done {
            border-color: rgba(127, 255, 127, 0.4);
            background: rgba(127, 255, 127, 0.05);
        }

        #story-goal-form input,
        #story-goal-form textarea {
            width: 100%;
            box-sizing: border-box;
            background: rgba(0, 0, 0, 0.3);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 6px;
            font-family: 'DotGothic16';
            font-size: 11px;
            margin-bottom: 6px;
            padding: 8px;
        }

        #story-goal-form textarea {
            min-height: 50px;
            resize: vertical;
        }

        .overlay-action {
            background: rgba(0, 180, 255, 0.2);
            color: #fff;
            border: 1px solid rgba(0, 180, 255, 0.4);
            border-radius: 6px;
            padding: 6px 10px;
            font-family: 'DotGothic16';
            font-size: 11px;
            cursor: pointer;
            margin-top: 4px;
        }

        .overlay-action:active {
            background: rgba(0, 180, 255, 0.4);
        }

        #status-bar {
            position: absolute;
            top: 15px;
            left: 15px;
            z-index: 1000;
            font-size: 12px;
            min-width: 130px;
            pointer-events: none;
        }

        #status-lv {
            font-size: 11px;
            color: #ffeb3b;
            margin-bottom: 4px;
            font-weight: bold;
            text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
        }

        #status-hp-text,
        #status-mp-text {
            position: relative;
            z-index: 2;
            font-size: 10px;
            font-weight: bold;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
        }

        #status-hp-bar,
        #status-mp-bar {
            background: rgba(255, 255, 255, 0.1);
            height: 14px;
            position: relative;
            margin-bottom: 4px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 4px;
            overflow: hidden;
        }

        #status-hp-fill {
            background: #4caf50;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            transition: width 0.3s;
            box-shadow: 0 0 8px rgba(76, 175, 80, 0.5);
        }

        #status-mp-fill {
            background: #2196f3;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            transition: width 0.3s;
            box-shadow: 0 0 8px rgba(33, 150, 243, 0.5);
        }

        @keyframes bar-move {
            0% {
                left: -60px;
            }

            100% {
                left: 100%;
            }
        }

        /* Resizing adjustments for small screens */
        @media (max-width: 600px) {
            #status-bar {
                top: 12px;
                left: 12px;
                min-width: 100px;
                padding: 8px;
            }

            #gui {
                top: 12px;
                right: 12px;
                width: 110px;
                padding: 8px;
                font-size: 8px;
            }

            #clock-text {
                font-size: 14px;
            }

            #weather-info {
                font-size: 9px;
                margin-bottom: 6px;
            }

            #debug-update-btn {
                padding: 3px;
                font-size: 8px;
            }

            #bag-gui {
                bottom: 15px;
                gap: 4px;
                width: 95%;
            }

            .game-btn {
                padding: 10px 4px;
                font-size: 10px;
                border-radius: 8px;
            }

            #inventory-window,
            #player-window,
            #quest-window {
                bottom: 65px;
                left: 2.5%;
                width: 95%;
                max-height: 50vh;
            }

            #battle-status-window {
                top: 12px;
                left: 2.5%;
                width: 95%;
            }

            #battle-command-window {
                bottom: 12px;
                left: 2.5%;
                width: 95%;
            }

            .battle-btn {
                padding: 8px 4px;
                font-size: 11px;
            }

            #message-window {
                bottom: 70px;
                font-size: 11px;
                padding: 10px 14px;
            }
        }
    </style>
</head>

<body>

    <div id="status-bar" class="glass-panel">
        <div id="status-lv">Lv 1</div>
        <div id="status-hp-bar">
            <div id="status-hp-fill"></div>
            <div id="status-hp-text">HP 30/30</div>
        </div>
        <div id="status-mp-bar">
            <div id="status-mp-fill"></div>
            <div id="status-mp-text">MP 10/10</div>
        </div>
    </div>

    <div id="gui" class="glass-panel">
        <span id="clock-text">00:00</span>
        <div id="weather-info">LOADING...</div>
        <button id="debug-update-btn" onclick="manualUpdate()">更新(デバッグ)</button>
        <button id="debug-update-btn" style="font-size:8px; margin-top:4px;" onclick="setManualPos()">位置を手入力する</button>
        <button id="debug-update-btn" style="font-size:8px; margin-top:4px;" onclick="retryGps()">GPS再取得</button>
        <div id="debug-log"
            style="font-size:8px; color:#0f0; margin-top:4px; text-align:left; border-top:1px solid rgba(255,255,255,0.15); padding-top:4px;">
            Log: Wait GPS</div>
    </div>

    <div id="bag-gui">
        <div id="inventory-window" class="glass-panel">
            <div style="border-bottom: 1px solid rgba(255,255,255,0.2); margin-bottom: 8px; padding-bottom: 4px;">どうぐ
            </div>
            <div id="item-list">なし</div>
        </div>
        <div id="player-window" class="glass-panel">
            <div>ゆうしゃ じょうほう</div>
            <div id="player-info"></div>
            <div id="player-items"></div>
            <div style="display: flex; gap: 4px; margin-top: 8px;">
                <button class="save-btn" onclick="saveGame()">セーブ</button>
                <button class="save-btn" onclick="changeJob()">転職</button>
                <button class="save-btn" onclick="setHome()">自宅設定</button>
            </div>
        </div>
        <div id="quest-window" class="glass-panel">
            <div>クエスト</div>
            <div id="quest-list"></div>
        </div>
        <button id="bag-btn" class="game-btn" onclick="toggleBag()">ふくろ</button>
        <button id="prep-btn" class="game-btn" onclick="openPrepMenu()">じゅんび</button>
        <button id="story-btn" class="game-btn" onclick="openStoryMenu()">ストーリー</button>
        <button id="quest-btn" class="game-btn" onclick="toggleQuestWindow()">クエスト</button>
    </div>

    <div id="prep-overlay" class="game-overlay">
        <div class="overlay-panel">
            <div class="overlay-title">じゅんび</div>
            <div class="overlay-tabs">
                <button class="overlay-tab active" data-prep-tab="status"
                    onclick="switchPrepTab('status')">ステータス</button>
                <button class="overlay-tab" data-prep-tab="equip" onclick="switchPrepTab('equip')">そうび</button>
                <button class="overlay-tab" data-prep-tab="heart" onclick="switchPrepTab('heart')">こころ</button>
                <button class="overlay-tab" data-prep-tab="job" onclick="switchPrepTab('job')">転職</button>
            </div>
            <div class="overlay-body" id="prep-body"></div>
            <button class="overlay-close" onclick="closePrepMenu()">とじる</button>
        </div>
    </div>

    <div id="story-overlay" class="game-overlay">
        <div class="overlay-panel">
            <div class="overlay-title">ストーリー</div>
            <div class="overlay-body" id="story-body"></div>
            <button class="overlay-close" onclick="closeStoryMenu()">とじる</button>
        </div>
    </div>

    <div id="message-window"></div>

    <div id="map-loading">
        <div class="load-window">
            <div class="load-text">ちず よみこみちゅう...</div>
            <div class="small-load-bar">
                <div class="small-load-fill"></div>
            </div>
            <button onclick="document.getElementById('map-loading').classList.remove('visible')"
                style="margin-top:15px; background:#444; color:#fff; border:1px solid #fff; font-size:10px;">とじる(強制)</button>
        </div>
    </div>

    <div id="battle-status-window" class="battle-window glass-panel">
        <div id="battle-title">たたかい</div>
        <div class="battle-hp">
            <div id="battle-player-hp">ゆうしゃ Lv1 HP: 24/24</div>
            <div id="battle-enemy-hp">まもの Lv1 HP: 16/16</div>
        </div>
        <div id="battle-log">まものが あらわれた！</div>
    </div>

    <div id="battle-command-window" class="battle-window glass-panel">
        <div class="battle-actions">
            <button class="battle-btn" id="battle-attack-btn">たたかう</button>
            <button class="battle-btn" id="battle-skill-btn">スキル</button>
            <button class="battle-btn" id="battle-run-btn">にげる</button>
            <button class="battle-btn" id="battle-guard-btn">ぼうぎょ</button>
            <button class="battle-btn" id="battle-item-btn">どうぐ</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>

    <script>
        let scene, camera, renderer, controls, roadLayer, mapLayer, slimeGroup;
        let baseCoords = null, lastFetchedCoords = null;
        let keyState = {};
        let isFetching = false;
        let isUpdatingMap = false;
        let spots = [], monsters = [];
        const ripples = [];
        const raycaster = new THREE.Raycaster();
        let currentWeather = "clear"; // "clear", "cloudy", "rain", "snow", "fog"
        let currentPeriod = "day"; // "day", "sunset", "night"
        let sunLight, ambientLight;
        let weatherParticleSystem = null;
        const clouds = [];
        const cloudGroup = new THREE.Group();
        const loadedMapElements = new Set();
        const mouse = new THREE.Vector2();
        const inventory = [];
        const ITEM_POOL = ["やくそう", "どうのつるぎ", "かわのたて", "どくけしそう", "スライムゼリー", "スライムコイン"];
        const ITEM_DEFS = {
            "やくそう": { type: "consumable", heal: 15 },
            "どくけしそう": { type: "consumable", heal: 8 },
            "まほうのせいすい": { type: "consumable", mpHeal: 10 },
            "スライムゼリー": { type: "consumable", heal: 8 },
            "どうのつるぎ": { type: "weapon", atk: 4 },
            "はがねのつるぎ": { type: "weapon", atk: 12 },
            "かわのたて": { type: "shield", def: 3 },
            "シルバートレイ": { type: "shield", def: 8 },
            "スライムのこころ": { type: "heart", atk: 1, def: 1, hp: 5, cost: 2 },
            "ドラキーのこころ": { type: "heart", atk: 3, def: 1, hp: 8, cost: 4 },
            "おおがらすのこころ": { type: "heart", atk: 4, def: 2, hp: 12, cost: 6 },
            "ゴーレムのこころ": { type: "heart", atk: 12, def: 8, hp: 30, cost: 18 },
            "キングスライムのこころ": { type: "heart", atk: 15, def: 10, hp: 40, cost: 25 },
            "スライムコイン": { type: "misc" }
        };
        const JOB_DEFS = {
            "戦士": { hp: 1.2, mp: 0.8, atk: 1.2, def: 1.2, skill: "ぶんまわし", skillDmg: 1.3, mpCost: 3 },
            "僧侶": { hp: 1.0, mp: 1.5, atk: 0.8, def: 1.0, skill: "ホイミ", heal: 25, mpCost: 4 },
            "魔法使い": { hp: 0.7, mp: 1.8, atk: 0.7, def: 0.7, skill: "メラゾーマ", skillDmg: 2.2, mpCost: 6 },
            "武闘家": { hp: 1.1, mp: 0.9, atk: 1.3, def: 0.9, skill: "せいけんづき", skillDmg: 1.6, mpCost: 4 }
        };
