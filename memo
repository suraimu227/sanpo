        function createBuildingMesh(el, pts2D, baseCoords, buildingFillMaterial, buildingLineMaterial) {
            if (loadedMapElements.has(el.id)) return;
            loadedMapElements.add(el.id);

            const shape = new THREE.Shape(pts2D);
            const buildingGeom = new THREE.ShapeGeometry(shape);
            const buildingMesh = new THREE.Mesh(buildingGeom, buildingFillMaterial.clone());
            buildingMesh.rotation.x = Math.PI / 2;
            buildingMesh.position.y = 0.26;
            buildingMesh.userData = {
                id: el.id,
