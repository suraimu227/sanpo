        function buildBatchedRoadMesh(segments, maxWays = 130, halfWidth = 5.8) {
            const allPos = [];
            const allIdx = [];
            let vOff = 0;
            const sorted = segments.slice().sort((a, b) => b.length - a.length).slice(0, maxWays);
            for (const pts of sorted) {
                if (pts.length < 2) continue;
                const segLeft = [];
                const segRight = [];
                for (let i = 0; i < pts.length; i++) {
                    const prev = pts[Math.max(0, i - 1)];
                    const next = pts[Math.min(pts.length - 1, i + 1)];
                    const dir = new THREE.Vector2(next.x - prev.x, next.y - prev.y);
                    if (dir.lengthSq() < 0.0001) continue;
                    dir.normalize();
                    const n = new THREE.Vector2(-dir.y, dir.x).multiplyScalar(halfWidth);
                    segLeft.push(pts[i].x + n.x, 0.245, pts[i].y + n.y);
                    segRight.push(pts[i].x - n.x, 0.245, pts[i].y - n.y);
                }
                const count = segLeft.length / 3;
                if (count < 2) continue;
                for (let i = 0; i < count - 1; i++) {
                    const a = vOff + i * 2;
                    allIdx.push(a, a + 1, a + 2, a + 1, a + 3, a + 2);
                }
                for (let i = 0; i < count; i++) {
                    allPos.push(segLeft[i * 3], segLeft[i * 3 + 1], segLeft[i * 3 + 2]);
                    allPos.push(segRight[i * 3], segRight[i * 3 + 1], segRight[i * 3 + 2]);
                }
                vOff += count * 2;
            }
            if (!allPos.length) return null;
            const geom = new THREE.BufferGeometry();
            geom.setAttribute("position", new THREE.Float32BufferAttribute(allPos, 3));
            geom.setIndex(allIdx);
            const mat = new THREE.MeshLambertMaterial({
                color: 0x707a88,
                emissive: 0x1a2230,
                emissiveIntensity: 0.35,
                polygonOffset: true,
                polygonOffsetFactor: -1,
                polygonOffsetUnits: -1
            });
            return new THREE.Mesh(geom, mat);
        }

        async function fetchMapData(lat, lon) {
            if (isFetching) return;
            if (!baseCoords) {
                addLog("Err: No BaseCoords");
                document.getElementById('map-loading').classList.remove('visible');
                return;
            }
            isFetching = true;
            lastFetchedCoords = { lat, lon };
            addLog(`Fetch: ${lat.toFixed(4)},${lon.toFixed(4)}`);
            document.getElementById('map-loading').classList.add('visible');

            const q = `[out:json][timeout:20];(way["highway"](around:${MAP_RADIUS},${lat},${lon});way["building"](around:${MAP_RADIUS},${lat},${lon}););out geom;`;

            let data = null;
            let success = false;

            try {
                addLog(`Try: /api/overpass`);
                const res = await fetch(`/api/overpass?data=${encodeURIComponent(q)}`);
                if (!res.ok) throw new Error("Status " + res.status);
                data = await res.json();
                if (data.error) throw new Error(data.error);
                success = true;
            } catch (e) {
                addLog(`Fail: Proxy (${e.message})`);
            }

            try {
                if (!success) throw new Error("Proxy fetch failed");

                if (!data || !data.elements) {
                    addLog("Warn: No Data Found");
                    data = { elements: [] };
                } else {
                    addLog(`Got ${data.elements.length} items`);
                }

                // レイヤーのクリア（clear()）を廃止し、新規要素のみを追加するように変更
                const buildingFillMaterial = new THREE.MeshLambertMaterial({
                    color: 0x5b6672,
                    side: THREE.DoubleSide,
                    transparent: true,
                    opacity: 0, // フェードインされるので初期値0
                    polygonOffset: true,
                    polygonOffsetFactor: -1,
                    polygonOffsetUnits: -2
                });
                const buildingLineMaterial = new THREE.LineBasicMaterial({ color: 0xbfc6cf });
                const roadMaterial = new THREE.MeshLambertMaterial({
                    color: 0x707a88,
                    emissive: 0x1a2230,
                    emissiveIntensity: 0.35,
                    polygonOffset: true,
                    polygonOffsetFactor: -1,
                    polygonOffsetUnits: -1,
                    transparent: true,
                    opacity: 0 // フェードインされるので初期値0
                });

                data.elements.forEach(el => {
                    if (!el.geometry || !el.tags) return;

                    const pts2D = el.geometry.map(p => {
                        const dx = (p.lon - baseCoords.lon) * ((Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180);
                        const dz = -(p.lat - baseCoords.lat) * ((2 * Math.PI * R) / 360);
                        return new THREE.Vector2(dx, dz);
                    });

                    if (el.tags.building) {
                        if (pts2D.length < 3) return;
                        createBuildingMesh(el, pts2D, baseCoords, buildingFillMaterial, buildingLineMaterial);
                    } else if (el.tags.highway) {
                        if (pts2D.length < 2) return;
                        createRoadMesh(el, pts2D, roadMaterial);
                    }
                });

                // 遠方の不要なマップ要素を破棄
                cleanupRemoteMapElements();

                if (spots.length === 0 && monsters.length === 0) createObjects();
                else if (playerState.homeCoords) createHomeMarker();
            } catch (e) {
                addLog("API Error: " + e.message);
                showMessage("ちずの よみこみに しっぱい");
            } finally {
                isFetching = false;
                setTimeout(() => document.getElementById('map-loading').classList.remove('visible'), 500);
            }
        }

        function createHomeMarker() {
            if (homeSpotGroup) {
                scene.remove(homeSpotGroup);
                homeSpotGroup = null;
            }
            if (!playerState.homeCoords || !baseCoords) return;
            const hx = (playerState.homeCoords.lon - baseCoords.lon) * ((Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180);
            const hz = -(playerState.homeCoords.lat - baseCoords.lat) * ((2 * Math.PI * R) / 360);
            homeSpotGroup = new THREE.Group();
            homeSpotGroup.position.set(hx, 0, hz);
            const house = new THREE.Mesh(new THREE.BoxGeometry(8, 6, 8), new THREE.MeshPhongMaterial({ color: 0xffaa00 }));
            house.position.y = 3; homeSpotGroup.add(house);
            const roof = new THREE.Mesh(new THREE.ConeGeometry(7, 5, 4), new THREE.MeshPhongMaterial({ color: 0xaa0000 }));
            roof.position.y = 8.5; roof.rotation.y = Math.PI / 4; homeSpotGroup.add(roof);
            const sign = new THREE.Mesh(new THREE.BoxGeometry(4, 1.5, 0.5), new THREE.MeshBasicMaterial({ color: 0xffffff }));
            sign.position.set(0, 10, 5); homeSpotGroup.add(sign);
            scene.add(homeSpotGroup);
            const existing = spots.find(s => s.type === "home");
            if (existing) {
                existing.group = homeSpotGroup;
                existing.active = true;
            } else {
                spots.push({ group: homeSpotGroup, type: "home", active: true });
            }
        }

        function createObjects() {
            spots.forEach(s => { if (s.type !== "home") scene.remove(s.group); });
            monsters.forEach(m => scene.remove(m.group));
            spots = spots.filter(s => s.type === "home");
            monsters = [];
            createHomeMarker();

            for (let i = 0; i < 18; i++) {
                const rx = (Math.random() - 0.5) * 1400 + slimeGroup.position.x;
                const rz = (Math.random() - 0.5) * 1400 + slimeGroup.position.z;
                const group = new THREE.Group();
                group.position.set(rx, 0, rz);

                const roll = Math.random();
                if (roll > 0.6) {
                    // 回復スポット or アイテム
                    const isRecovery = Math.random() > 0.5;
                    const color = isRecovery ? 0x00ffff : 0x00ff00;
                    const p = new THREE.Mesh(new THREE.CylinderGeometry(1.2, 1.2, 18, 8), new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.6 }));
                    p.position.y = 9; group.add(p); scene.add(group);
                    spots.push({ group, type: isRecovery ? "recovery" : "item", active: true });
                } else {
                    // 通常モンスター or メガモンスター（低確率ボス）
                    const isMega = Math.random() > 0.94;
                    const enemyType = isMega ? MEGA_MONSTER_TYPES[Math.floor(Math.random() * MEGA_MONSTER_TYPES.length)] : ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
                    const enemyLv = isMega ? 10 : (1 + Math.floor(Math.random() * Math.max(1, playerState.lv + 1)));
                    const scale = enemyType.scale || 1.0;

                    const enemyStats = {
                        name: (isMega ? "[MEGA] " : "") + enemyType.name,
                        lv: enemyLv,
                        maxHp: enemyType.baseHp + enemyLv * 5,
                        hp: enemyType.baseHp + enemyLv * 5,
                        atk: enemyType.baseAtk + enemyLv * 3,
                        def: enemyType.baseDef + enemyLv * 2,
                        exp: enemyType.exp + enemyLv * 5,
                        drops: enemyType.drops,
                        isMega: isMega
                    };

                    const b = new THREE.Mesh(new THREE.SphereGeometry(3 * scale, 16, 16), new THREE.MeshPhongMaterial({ color: isMega ? 0x8800ff : 0xff4444 }));
                    b.position.y = 3 * scale; group.add(b);
                    const mark = createEmoteMark();
                    mark.position.y = 12 * scale; mark.visible = isMega;
                    group.add(mark);
                    scene.add(group);
                    monsters.push({ group, mark, active: true, velocity: new THREE.Vector3(0, 0, 0), nextMoveTime: 0, stats: enemyStats });
                }
            }
        }

        function createEmoteMark() {
            const group = new THREE.Group();
            const top = new THREE.Mesh(new THREE.BoxGeometry(0.8, 4, 0.8), new THREE.MeshBasicMaterial({ color: 0xff0000 }));
            const dot = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.8, 0.8), new THREE.MeshBasicMaterial({ color: 0xff0000 }));
            dot.position.y = -3; group.add(top); group.add(dot);
            return group;
        }

        function handleInteraction() {
            spots.forEach(s => {
                if (s.active && slimeGroup.position.distanceTo(s.group.position) < 11) {
                    if (s.type === "recovery") {
                        s.active = false;
                        const pStats = getPlayerBattleStats();
                        playerState.hp = pStats.maxHp;
                        playerState.mp = pStats.maxMp;
                        showMessage("HP・MPが まんたんに なった！");
                        scene.remove(s.group);
                    } else if (s.type === "item") {
                        s.active = false;
                        const item = ITEM_POOL[Math.floor(Math.random() * ITEM_POOL.length)];
                        inventory.push(item);
                        updateInventoryUI();
                        addQuestProgress("pickup", 1);
                        showMessage(`${item}を みつけた！`);
                        scene.remove(s.group);
                    } else if (s.type === "home") {
                        const pStats = getPlayerBattleStats();
                        if (playerState.hp < pStats.maxHp || playerState.mp < pStats.maxMp) {
                            playerState.hp = pStats.maxHp;
                            playerState.mp = pStats.maxMp;
                            showMessage("自宅で やすんで HP・MP全回復！");
                        }
                    }
                }
            });
            monsters.forEach(m => {
                if (m.active && slimeGroup.position.distanceTo(m.group.position) < 11) {
                    beginBattle(m);
                }
            });
        }

        function setupBattleUI() {
            document.getElementById('battle-attack-btn').addEventListener('click', onBattleAttack);
            document.getElementById('battle-skill-btn').addEventListener('click', onBattleSkill);
            document.getElementById('battle-run-btn').addEventListener('click', onBattleRun);
            document.getElementById('battle-guard-btn').addEventListener('click', onBattleGuard);
            document.getElementById('battle-item-btn').addEventListener('click', onBattleItem);
            document.getElementById('player-items').addEventListener('click', onPlayerItemAction);
        }

        function initQuestState() {
            QUEST_MASTER.forEach(q => {
                if (questProgress[q.id] == null) questProgress[q.id] = 0;
                if (questDone[q.id] == null) questDone[q.id] = false;
            });
        }

        function addQuestProgress(type, amount) {
            let anyComplete = false;
            for (const q of QUEST_MASTER) {
                if (q.type !== type || questDone[q.id]) continue;
                questProgress[q.id] += amount;
                if (questProgress[q.id] >= q.target) {
                    questDone[q.id] = true;
                    playerState.gold += q.rewardGold;
                    if (q.rewardItem) inventory.push(q.rewardItem);
                    showMessage(`クエスト達成: ${q.name}\n${q.rewardGold}G かくとく`);
                    anyComplete = true;
                }
            }
            if (anyComplete) updateInventoryUI();
            updateQuestWindow();
        }

        function toggleQuestWindow() {
            const win = document.getElementById('quest-window');
            const visible = win.style.display === 'block';
            win.style.display = visible ? 'none' : 'block';
            if (!visible) updateQuestWindow();
        }

        function updateQuestWindow() {
            const el = document.getElementById('quest-list');
            const today = new Date().toLocaleDateString("ja-JP");
            const rows = [`<div style="color:#ff9;margin-bottom:8px;">今日: ${today}</div>`];
            QUEST_MASTER.forEach(q => {
                const progress = Math.min(q.target, questProgress[q.id] || 0);
                const done = questDone[q.id];
                const state = done ? "達成" : `${Math.floor(progress)}/${q.target}`;
                rows.push(`<div style="margin-bottom:8px;">${q.name}<br><span style="color:${done ? "#7fffa5" : "#ddd"}">${state}</span></div>`);
            });
            el.innerHTML = rows.join("");
        }

        function saveGame(silent = false) {
            const payload = {
                playerState,
                inventory,
                questProgress,
                questDone,
                walkedDistance,
                storyState
            };
            localStorage.setItem("dqw_like_save", JSON.stringify(payload));
            if (!silent) showMessage("セーブしました");
        }

        function loadGame() {
            const raw = localStorage.getItem("dqw_like_save");
            if (!raw) return;
            try {
                const data = JSON.parse(raw);
                if (data.playerState) Object.assign(playerState, data.playerState);
                if (Array.isArray(data.inventory)) {
                    inventory.length = 0;
                    data.inventory.forEach(i => inventory.push(i));
                }
                if (data.questProgress) questProgress = data.questProgress;
                if (data.questDone) questDone = data.questDone;
                if (typeof data.walkedDistance === "number") walkedDistance = data.walkedDistance;
                if (data.storyState) storyState = { ...storyState, ...data.storyState };
            } catch (e) {
                // ignore broken save
            }
        }

        function applyLoginBonus() {
            const today = new Date().toISOString().slice(0, 10);
            const last = localStorage.getItem("dqw_login_last");
            if (last === today) return;

            // 日付が変わったらクエストリセット
            QUEST_MASTER.forEach(q => {
                questProgress[q.id] = 0;
                questDone[q.id] = false;
            });

            localStorage.setItem("dqw_login_last", today);
            playerState.gold += 100;
            inventory.push("やくそう");
            showMessage("日替わりボーナス: 100G と やくそう\nクエストを更新しました");
        }

        function setHome() {
            if (!lastFetchedCoords) {
                showMessage("位置情報がありません");
                return;
            }
            playerState.homeCoords = { ...lastFetchedCoords };
            playerState.homeSet = true;
            createHomeMarker();
            showMessage("ここを 自宅に設定しました！\n近づくと HP・MP回復");
            saveGame(true);
        }

        function changeJob() {
            const jobs = Object.keys(JOB_DEFS);
            const currentIndex = jobs.indexOf(playerState.job);
            const nextIndex = (currentIndex + 1) % jobs.length;
            playerState.job = jobs[nextIndex];
            showMessage(`職業を ${playerState.job} に変更した！`);
            updatePlayerWindow();
            renderPrepBody();
        }

        function openPrepMenu() {
            if (isInBattle) return;
            document.getElementById('prep-overlay').classList.add('open');
            renderPrepBody();
        }

        function closePrepMenu() {
            document.getElementById('prep-overlay').classList.remove('open');
        }

        function switchPrepTab(tab) {
            prepTab = tab;
            document.querySelectorAll('.overlay-tab[data-prep-tab]').forEach(el => {
                el.classList.toggle('active', el.dataset.prepTab === tab);
            });
            renderPrepBody();
        }

        function equipItemAt(idx) {
            const item = inventory[idx];
            if (!item) return;
            const def = ITEM_DEFS[item] || { type: "misc" };
            if (def.type === "heart") {
                if (def.cost > playerState.maxCost) {
                    showMessage(`コスト不足！(必要:${def.cost}/最大:${playerState.maxCost})`);
                    return;
                }
                if (playerState.equipment.heart) inventory.push(playerState.equipment.heart);
                playerState.equipment.heart = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "weapon") {
                if (playerState.equipment.weapon) inventory.push(playerState.equipment.weapon);
                playerState.equipment.weapon = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "shield") {
                if (playerState.equipment.shield) inventory.push(playerState.equipment.shield);
                playerState.equipment.shield = item;
                inventory.splice(idx, 1);
                showMessage(`${item}を そうびした`);
            } else if (def.type === "consumable") {
                const pStats = getPlayerBattleStats();
                if (def.heal) playerState.hp = Math.min(pStats.maxHp, playerState.hp + def.heal);
                if (def.mpHeal) playerState.mp = Math.min(pStats.maxMp, playerState.mp + def.mpHeal);
                inventory.splice(idx, 1);
                showMessage(`${item}を つかった`);
            }
            playerState.hp = Math.min(playerState.hp, getPlayerBattleStats().maxHp);
            playerState.mp = Math.min(playerState.mp, getPlayerBattleStats().maxMp);
            updateInventoryUI();
            updatePlayerWindow();
            renderPrepBody();
        }

        function renderPrepBody() {
            const el = document.getElementById('prep-body');
            const bonus = getEquippedBonus();
            const pStats = getPlayerBattleStats();
            const job = JOB_DEFS[playerState.job] || JOB_DEFS["戦士"];

            if (prepTab === "status") {
                el.innerHTML = [
                    `<span style="color:#ff9">職業: ${playerState.job}</span>`,
                    `Lv ${playerState.lv}  EXP ${playerState.exp}/${playerState.nextExp}`,
                    `HP ${playerState.hp}/${pStats.maxHp}  MP ${playerState.mp}/${pStats.maxMp}`,
                    `GOLD ${playerState.gold}`,
                    `こうげき ${pStats.atk}  しゅび ${pStats.def}`,
                    `こころコスト ${bonus.cost}/${playerState.maxCost}`,
                    `歩行 ${Math.floor(walkedDistance)}m`,
                    `戦闘勝利 ${storyState.battleWins}回`
                ].join("<br>");
                return;
            }

            if (prepTab === "equip") {
                const rows = inventory.map((item, idx) => {
                    const def = ITEM_DEFS[item] || {};
                    if (def.type !== "weapon" && def.type !== "shield") return "";
                    return `<div class="prep-equip-row"><span>${item}</span><button class="overlay-action" onclick="equipItemAt(${idx})">そうび</button></div>`;
                }).filter(Boolean).join("") || "装備できるどうぐが ない";
                el.innerHTML = `<div>ぶき: ${playerState.equipment.weapon || "なし"}</div><div>たて: ${playerState.equipment.shield || "なし"}</div><hr style="border-color:#444">${rows}`;
                return;
            }

            if (prepTab === "heart") {
                const rows = inventory.map((item, idx) => {
                    const def = ITEM_DEFS[item] || {};
                    if (def.type !== "heart") return "";
                    return `<div class="prep-equip-row"><span>${item} (コスト${def.cost})</span><button class="overlay-action" onclick="equipItemAt(${idx})">そうび</button></div>`;
                }).filter(Boolean).join("") || "こころを もっていない";
                el.innerHTML = `<div>そうび中: ${playerState.equipment.heart || "なし"}</div><hr style="border-color:#444">${rows}`;
                return;
            }

            if (prepTab === "job") {
                const jobs = Object.keys(JOB_DEFS);
                el.innerHTML = jobs.map(j => {
                    const d = JOB_DEFS[j];
                    const cur = j === playerState.job ? " ← いま" : "";
                    return `<div style="margin-bottom:10px;"><b>${j}</b>${cur}<br>スキル: ${d.skill} (MP${d.mpCost})</div>`;
                }).join("") + `<button class="overlay-action" onclick="changeJob()">つぎの職業へ 転職</button>`;
            }
        }

        function openStoryMenu() {
            if (isInBattle) return;
            document.getElementById('story-overlay').classList.add('open');
            renderStoryBody();
        }

        function closeStoryMenu() {
            document.getElementById('story-overlay').classList.remove('open');
        }

        function renderStoryBody() {
            const el = document.getElementById('story-body');
            const tutLines = TUTORIAL_CHAPTERS.map(ch => {
                const done = storyState.tutorialDone[ch.key];
                return `<div style="color:${done ? '#7f7' : '#aaa'};margin-bottom:4px;">${done ? "✓" : "・"} 章${ch.id}</div>`;
            }).join("");

            const goalCards = storyState.goals.map((g, i) => {
                const st = g.reached ? "達成" : "未達";
                return `<div class="story-goal-card ${g.reached ? 'done' : ''}"><b>${g.title}</b> [${st}]<br><span style="color:#ccc;font-size:10px;">${g.text.slice(0, 40)}...</span></div>`;
            }).join("") || "<div style='color:#888'>目的地は まだない</div>";

            el.innerHTML = `
            <div style="margin-bottom:12px;color:#ff9;">チュートリアル進行</div>${tutLines}
            <div style="margin:14px 0 8px;border-top:2px solid #444;padding-top:8px;color:#ff9;">あなたの物語・目的地</div>
            ${goalCards}
            <div id="story-goal-form" style="margin-top:12px;border-top:2px solid #444;padding-top:8px;">
                <input id="story-title" placeholder="目的地の名前（例: かえりみちの公園）" />
                <textarea id="story-text" placeholder="到着時に表示する物語（ひと言でもOK）"></textarea>
                <button class="overlay-action" onclick="addStoryGoalFromCurrent()">いまの場所を 目的地にする</button>
            </div>`;
        }

        function addStoryGoalFromCurrent() {
            if (!baseCoords || !lastFetchedCoords) {
                showMessage("位置が まだ取得できていません");
                return;
            }
            const title = document.getElementById('story-title')?.value?.trim() || "目的地";
            const text = document.getElementById('story-text')?.value?.trim() || `${title}に たどりついた。`;
            const latScale = (2 * Math.PI * R) / 360;
            const lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;
            const lat = baseCoords.lat - (slimeGroup.position.z / latScale);
            const lon = baseCoords.lon + (slimeGroup.position.x / lonScale);
            storyState.goals.push({ id: "g" + Date.now(), title, text, lat, lon, reached: false });
            storyState.goalSetCount += 1;
            checkTutorialProgress();
            saveGame(true);
            showMessage(`「${title}」を 目的地に設定した！`);
            renderStoryBody();
        }

        function showTutorialChapter(ch) {
            if (storyState.tutorialDone[ch.key]) return;
            storyState.tutorialDone[ch.key] = true;
            showMessage(ch.text);
            saveGame(true);
        }

        function checkTutorialProgress() {
            TUTORIAL_CHAPTERS.forEach(ch => {
                if (storyState.tutorialDone[ch.key]) return;
                if (ch.key === "start") return;
                if (ch.needWalk && walkedDistance >= ch.needWalk) showTutorialChapter(ch);
                if (ch.needWins && storyState.battleWins >= ch.needWins) showTutorialChapter(ch);
                if (ch.needGoalSet && storyState.goalSetCount >= 1) showTutorialChapter(ch);
                if (ch.needGoalReach && storyState.goalReachCount >= 1) showTutorialChapter(ch);
            });
        }

        function checkStoryArrival() {
            if (!baseCoords || isInBattle) return;
            const latScale = (2 * Math.PI * R) / 360;
            const lonScale = (Math.PI * R * Math.cos(baseCoords.lat * Math.PI / 180)) / 180;
            const playerLat = baseCoords.lat - (slimeGroup.position.z / latScale);
            const playerLon = baseCoords.lon + (slimeGroup.position.x / lonScale);
            let anyNew = false;
            storyState.goals.forEach(g => {
                if (g.reached) return;
                const dLat = (playerLat - g.lat) * latScale;
                const dLon = (playerLon - g.lon) * lonScale;
                const dist = Math.sqrt(dLat * dLat + dLon * dLon);
                if (dist < 45) {
                    g.reached = true;
                    storyState.goalReachCount += 1;
                    anyNew = true;
                    showMessage(`【${g.title}】\n\n${g.text}`);
                }
            });
            if (anyNew) {
                checkTutorialProgress();
                saveGame(true);
            }
        }

        function getEquippedBonus() {
            const weapon = playerState.equipment.weapon ? ITEM_DEFS[playerState.equipment.weapon] : null;
            const shield = playerState.equipment.shield ? ITEM_DEFS[playerState.equipment.shield] : null;
            const heart = playerState.equipment.heart ? ITEM_DEFS[playerState.equipment.heart] : null;
            return {
                atk: (weapon?.atk || 0) + (heart?.atk || 0),
                def: (shield?.def || 0) + (heart?.def || 0),
                hp: (heart?.hp || 0),
                cost: (heart?.cost || 0)
            };
        }

        function getPlayerBattleStats() {
            const bonus = getEquippedBonus();
            const job = JOB_DEFS[playerState.job] || JOB_DEFS["戦士"];
            return {
                atk: Math.floor((playerState.atk + bonus.atk) * job.atk),
                def: Math.floor((playerState.def + bonus.def) * job.def),
                maxHp: Math.floor((playerState.maxHp + bonus.hp) * job.hp),
                maxMp: Math.floor(playerState.maxMp * job.mp)
            };
        }

        function togglePlayerWindow() {
            const win = document.getElementById('player-window');
            const visible = win.style.display === 'block';
            win.style.display = visible ? 'none' : 'block';
            if (!visible) updatePlayerWindow();
        }

        function updateStatusBar() {
            try {
                const pStats = getPlayerBattleStats();
                const lvEl = document.getElementById('status-lv');
                const hpT = document.getElementById('status-hp-text');
                const mpT = document.getElementById('status-mp-text');
                const hpF = document.getElementById('status-hp-fill');
                const mpF = document.getElementById('status-mp-fill');

                if (lvEl) lvEl.textContent = `Lv ${playerState.lv} ${playerState.job}`;
                if (hpT) hpT.textContent = `HP ${Math.max(0, playerState.hp)}/${pStats.maxHp}`;
                if (mpT) mpT.textContent = `MP ${playerState.mp}/${pStats.maxMp}`;

                const hpPct = (playerState.hp / pStats.maxHp) * 100;
                const mpPct = (playerState.mp / pStats.maxMp) * 100;

                if (hpF) {
                    hpF.style.width = `${Math.max(0, Math.min(100, hpPct))}%`;
                    hpF.style.background = hpPct < 25 ? '#f00' : '#0f0';
                }
                if (mpF) {
                    mpF.style.width = `${Math.max(0, Math.min(100, mpPct))}%`;
                }
            } catch (e) {
                console.error("StatusBar Error:", e);
            }
        }

        function updatePlayerWindow() {
            updateStatusBar();
            const bonus = getEquippedBonus();
            const pStats = getPlayerBattleStats();
            const info = document.getElementById('player-info');
            info.innerHTML = [
                `<span style="color:#ff0">職業: ${playerState.job}</span>`,
                `Lv ${playerState.lv}`,
                `HP ${playerState.hp}/${pStats.maxHp}`,
                `MP ${playerState.mp}/${pStats.maxMp}`,
                `EXP ${playerState.exp}/${playerState.nextExp}`,
