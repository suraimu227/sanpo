        function setupWeatherParticles() {
            if (weatherParticleSystem) {
                scene.remove(weatherParticleSystem);
                weatherParticleSystem.geometry.dispose();
                weatherParticleSystem.material.dispose();
                weatherParticleSystem = null;
            }

            if (currentWeather !== "rain" && currentWeather !== "snow") return;

            const particleCount = currentWeather === "rain" ? 1200 : 600;
            const geometry = new THREE.BufferGeometry();
            const positions = [];
            const velocities = [];

            for (let i = 0; i < particleCount; i++) {
                positions.push(
                    (Math.random() - 0.5) * 120,
                    Math.random() * 45,
                    (Math.random() - 0.5) * 120
                );

                if (currentWeather === "rain") {
                    velocities.push(0, -(0.6 + Math.random() * 0.4), 0);
                } else {
                    velocities.push(
                        (Math.random() - 0.5) * 0.1,
                        -(0.08 + Math.random() * 0.08),
                        (Math.random() - 0.5) * 0.1
                    );
                }
            }

            geometry.setAttribute('position', new THREE.Float32BufferAttribute(positions, 3));
            geometry.userData = { velocities };

            let material;
            if (currentWeather === "rain") {
                material = new THREE.PointsMaterial({
                    color: 0xddddff,
                    size: 0.4,
                    transparent: true,
                    opacity: 0.6
                });
            } else {
                material = new THREE.PointsMaterial({
                    color: 0xffffff,
                    size: 0.9,
                    transparent: true,
                    opacity: 0.8
                });
            }

            weatherParticleSystem = new THREE.Points(geometry, material);
            if (slimeGroup) weatherParticleSystem.position.copy(slimeGroup.position);
            scene.add(weatherParticleSystem);
        }

        function updateWeatherParticles() {
            if (!weatherParticleSystem || !slimeGroup) return;

            weatherParticleSystem.position.copy(slimeGroup.position);

            const positionAttr = weatherParticleSystem.geometry.attributes.position;
            const positions = positionAttr.array;
            const velocities = weatherParticleSystem.geometry.userData.velocities;

            for (let i = 0; i < positionAttr.count; i++) {
                const i3 = i * 3;
                positions[i3 + 0] += velocities[i3 + 0];
                positions[i3 + 1] += velocities[i3 + 1];
                positions[i3 + 2] += velocities[i3 + 2];

                if (currentWeather === "snow") {
                    velocities[i3 + 0] = Math.sin(performance.now() * 0.002 + i) * 0.04;
                }

                if (positions[i3 + 1] < 0) {
                    positions[i3 + 0] = (Math.random() - 0.5) * 120;
                    positions[i3 + 1] = 45;
                    positions[i3 + 2] = (Math.random() - 0.5) * 120;
                }
            }
            positionAttr.needsUpdate = true;
        }

        function setupCloudObjects() {
            clouds.forEach(c => cloudGroup.remove(c));
            clouds.length = 0;

            let cloudCount = 0;
            if (currentWeather === "clear") {
                cloudCount = 3;
            } else if (currentWeather === "cloudy" || currentWeather === "fog") {
                cloudCount = 15;
            } else if (currentWeather === "rain" || currentWeather === "snow") {
                cloudCount = 10;
            }

            const cloudMaterial = new THREE.MeshLambertMaterial({
                color: currentWeather === "clear" ? 0xffffff : 0x778899,
                transparent: true,
                opacity: currentWeather === "clear" ? 0.35 : 0.65,
                flatShading: true
            });

            for (let i = 0; i < cloudCount; i++) {
                const group = new THREE.Group();
                const partCount = 3 + Math.floor(Math.random() * 4);
                for (let j = 0; j < partCount; j++) {
                    const w = 4 + Math.random() * 6;
                    const h = 2 + Math.random() * 3;
                    const d = 4 + Math.random() * 6;
                    const geom = new THREE.SphereGeometry(w, 8, 8);
                    geom.scale(1, h / w, d / w);

                    const mesh = new THREE.Mesh(geom, cloudMaterial);
                    mesh.position.set(
                        (Math.random() - 0.5) * 12,
                        (Math.random() - 0.5) * 2,
